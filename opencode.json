{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "gyoshu",
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow"
  },
  "plugin": [
    "oh-my-opencode",
    "opencode-openai-codex-auth",
    "opencode-antigravity-auth"
  ],
  "agent": {
    "build": {
      "tools": {
        "write": true,
        "edit": true,
        "read": true,
        "bash": true
      },
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "general": {
      "tools": {
        "write": true,
        "edit": true,
        "read": true,
        "bash": true,
        "webfetch": true
      },
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow"
      }
    }
  },
  "lsp": {
    "basedpyright": {
      "command": [
        "basedpyright",
        "--stdio"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    },
    "pyright": {
      "disabled": true
    }
  },
  "mcp": {
    "context7": {
      "command": [
        "bunx",
        "--bun",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "environment": {},
      "type": "local"
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"]
    }
  }
}
